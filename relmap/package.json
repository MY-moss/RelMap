{
  "name": "relmap",
  "private": true,
  "version": "2.0.0",
  "description": "RelMap - 智能关系管理助手",
  "author": "RelMap Team <relmap@example.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "smoke": "npx tsx tests/smoke/smoke-test.ts",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.ts --ui",
    "preview": "vite preview",
    "benchmark": "npx tsx tests/benchmarks/run-benchmarks.ts",
    "benchmark:history": "npx tsx tests/benchmarks/compare-benchmarks.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "analyze": "node scripts/analyze-bundle.mjs",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint:ts": "tsc --noEmit",
    "lint:ts:electron": "tsc -p electron/tsconfig.json --noEmit",
    "seed": "node scripts/seed-data.mjs",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@sentry/electron": "^7.15.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-text-style": "^3.27.4",
    "@tiptap/extension-underline": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "cytoscape": "^3.34.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "lucide-react": "^1.24.0",
    "pino": "^10.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.9",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "type-fest": "^5.8.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.relmap.app",
    "productName": "RelMap",
    "asar": true,
    "asarUnpack": [
      "**/*.{node,dll}",
      "node_modules/better-sqlite3-multiple-ciphers/**",
      "node_modules/@sentry/**",
      "node_modules/electron-updater/**"
    ],
    "directories": {
      "output": "release_v4",
      "buildResources": "public"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "dist/*.svg",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.{md,markdown}",
      "!**/.{idea,git,cache,vscode,DS_Store}"
    ],
    "win": {
      "target": ["portable"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MY-moss/RelMap.git"
  },
  "main": "dist-electron/main.mjs",
  "optionalDependencies": {
    "canvas": "^3.1.0",
    "face-api.js": "^0.22.2"
  }
}
